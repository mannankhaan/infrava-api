generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  OPERATIVE
}

enum FaultStatus {
  CREATED
  ASSIGNED_TO_OPERATIVE
  OPERATIVE_SUBMITTED
  REJECTED
  REASSIGNED
  ADMIN_SUBMITTED
  COMPLETED
}

enum PunchEventType {
  PUNCH_IN
  REACHED
  WORK_DONE
  PUNCH_OUT
}

enum QuotationStatus {
  DRAFT
  FINAL
}

// ─── USERS ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          UserRole
  adminId       String?   @map("admin_id") @db.Uuid
  companyName    String?   @map("company_name")
  companyAddress String?   @map("company_address")
  companyWebsite String?   @map("company_website")
  companyPhone   String?   @map("company_phone")
  companyEmail   String?   @map("company_email")
  companyAbn     String?   @map("company_abn")
  logoUrl        String?   @map("logo_url")
  emailVerified  Boolean   @default(false) @map("email_verified")
  isApproved     Boolean   @default(false) @map("is_approved")
  avatarUrl      String?   @map("avatar_url")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  permissions Json?    @db.JsonB // Manager permissions: { clients, features }

  // Self-referencing: admin → operatives/managers
  admin      User?  @relation("AdminOperatives", fields: [adminId], references: [id])
  operatives User[] @relation("AdminOperatives")

  // Faults relations
  adminFaults             Fault[] @relation("AdminFaults")
  createdFaults           Fault[] @relation("FaultCreator")
  operativeAssignedFaults Fault[] @relation("FaultOperative")

  // Client relations
  clients Client[] @relation("AdminClients")

  // Other relations
  refreshTokens            RefreshToken[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  faultAuditLogs           FaultAuditLog[]
  auditLogs                AuditLog[]
  eodReports               EodReport[]

  requestedDeletions DataDeletionRequest[] @relation("DeletionRequester")
  targetedDeletions  DataDeletionRequest[] @relation("DeletionTarget")
  processedDeletions DataDeletionRequest[] @relation("DeletionProcessor")

  quotations Quotation[] @relation("AdminQuotations")
  rateCards  RateCard[]  @relation("AdminRateCards")
  formTemplates FormTemplate[] @relation("AdminFormTemplates")
  projectSequences   ProjectSequence[]   @relation("AdminProjectSequences")
  quotationSequences QuotationSequence[] @relation("AdminQuotationSequences")

  @@map("users")
}

// ─── CLIENTS ────────────────────────────────────────────────────────

model Client {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId            String   @map("admin_id") @db.Uuid
  name               String
  address            String?
  referenceNumber    String?  @map("reference_number")
  logoR2Key          String?  @map("logo_r2_key")
  opsContactName     String?  @map("ops_contact_name")
  opsContactEmail    String?  @map("ops_contact_email")
  opsContactPhone    String?  @map("ops_contact_phone")
  comContactName     String?  @map("com_contact_name")
  comContactEmail    String?  @map("com_contact_email")
  comContactPhone    String?  @map("com_contact_phone")
  email1             String?
  email2             String?
  projectCode        String?  @map("project_code")
  projectDescription String?  @map("project_description")
  contractPdfR2Key   String?  @map("contract_pdf_r2_key")
  clientRefPrefix    String?  @map("client_ref_prefix")
  isActive           Boolean  @default(true) @map("is_active")
  projectSequence    ProjectSequence?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  formTemplateId  String?       @map("form_template_id") @db.Uuid

  admin              User                @relation("AdminClients", fields: [adminId], references: [id])
  faults             Fault[]             @relation("ClientFaults")
  quotations         Quotation[]         @relation("ClientQuotations")
  rateCards          RateCard[]          @relation("ClientRateCards")
  formTemplate       FormTemplate?       @relation("ClientFormTemplate", fields: [formTemplateId], references: [id])
  quotationSequence  QuotationSequence?

  @@unique([adminId, name])
  @@map("clients")
}

// ─── PROJECT SEQUENCES (per-client atomic counters) ─────────────────

model ProjectSequence {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String @unique @map("client_id") @db.Uuid
  adminId    String @map("admin_id") @db.Uuid
  prefix     String
  lastNumber Int    @default(0) @map("last_number")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  admin  User   @relation("AdminProjectSequences", fields: [adminId], references: [id])

  @@unique([adminId, prefix])
  @@map("project_sequences")
}

model QuotationSequence {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String @unique @map("client_id") @db.Uuid
  adminId    String @map("admin_id") @db.Uuid
  prefix     String
  lastNumber Int    @default(0) @map("last_number")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  admin  User   @relation("AdminQuotationSequences", fields: [adminId], references: [id])

  @@unique([adminId, prefix])
  @@map("quotation_sequences")
}

// ─── FORM TEMPLATES ─────────────────────────────────────────────────

model FormTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId   String   @map("admin_id") @db.Uuid
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  schema    Json     @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  admin   User     @relation("AdminFormTemplates", fields: [adminId], references: [id])
  clients Client[] @relation("ClientFormTemplate")
  faults  Fault[]  @relation("FaultFormTemplate")

  @@unique([adminId, name])
  @@map("form_templates")
}

// ─── FAULTS ─────────────────────────────────────────────────────────

model Fault {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId   String @map("admin_id") @db.Uuid
  clientId  String? @map("client_id") @db.Uuid

  // System-generated human-readable reference (e.g. NR-0001)
  projectRef String  @unique @map("project_ref")

  // Optional external references from client
  clientRef  String? @map("client_ref")
  companyRef String? @map("company_ref")

  // Fault info
  title       String
  workType    String? @map("work_type")
  description String?

  // Location
  locationText String? @map("location_text")
  locationLat  Float?  @map("location_lat")
  locationLng  Float?  @map("location_lng")

  // Scheduling
  timeAllocated     DateTime? @map("time_allocated") @db.Timestamptz()
  plannedArrival    DateTime? @map("planned_arrival") @db.Timestamptz()
  plannedCompletion DateTime? @map("planned_completion") @db.Timestamptz()
  priority          String? // "2h" | "24h" | "7d" | "28d" | "Planned" | "Project"

  // Onsite Contact
  onsiteContactName  String? @map("onsite_contact_name")
  onsiteContactPhone String? @map("onsite_contact_phone")
  onsiteContactEmail String? @map("onsite_contact_email")

  // Visit Requirements
  visitTaskBriefing      Boolean @default(false) @map("visit_task_briefing")
  visitLsr               Boolean @default(false) @map("visit_lsr")
  visitLinkBlock         Boolean @default(false) @map("visit_link_block")
  visitSafeWorkPack      Boolean @default(false) @map("visit_safe_work_pack")
  visitPossession        Boolean @default(false) @map("visit_possession")
  visitTempWorks         Boolean @default(false) @map("visit_temp_works")
  visitIsolation         Boolean @default(false) @map("visit_isolation")
  visitTrackAccess       Boolean @default(false) @map("visit_track_access")
  visitTempWorksRequired Boolean @default(false) @map("visit_temp_works_required")
  visitWorkingAtHeight   Boolean @default(false) @map("visit_working_at_height")

  // Contractor Details
  contractorCompany String? @map("contractor_company")
  contractorName    String? @map("contractor_name")
  contractorEmail   String? @map("contractor_email")
  contractorMobile  String? @map("contractor_mobile")

  // Operative-filled fields
  supervisorNames  String?  @map("supervisor_names")
  operativeName    String?  @map("operative_name")
  materialsUsed    Json?    @map("materials_used") @db.JsonB // [{item, qty, unit}]
  methodology      String?
  worksDescription String?  @map("works_description")
  dimensions       Json?    @db.JsonB // [{activity, qty, unit}]
  furtherWork      Boolean? @map("further_work")
  furtherWorkNotes String?  @map("further_work_notes")

  // Dynamic form fields
  customFields    Json?   @map("custom_fields") @db.JsonB
  formTemplateId  String? @map("form_template_id") @db.Uuid
  formTemplate    FormTemplate? @relation("FaultFormTemplate", fields: [formTemplateId], references: [id])

  // Status & Ownership
  status               FaultStatus @default(CREATED)
  createdBy            String      @map("created_by") @db.Uuid
  assignedOperativeId  String?     @map("assigned_operative_id") @db.Uuid
  faultDate            DateTime    @default(dbgenerated("CURRENT_DATE")) @map("fault_date") @db.Date
  operativeSubmittedAt DateTime?   @map("operative_submitted_at") @db.Timestamptz()
  adminSubmittedAt     DateTime?   @map("admin_submitted_at") @db.Timestamptz()
  completedAt          DateTime?   @map("completed_at") @db.Timestamptz()
  rejectionNote        String?     @map("rejection_note")
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  admin             User            @relation("AdminFaults", fields: [adminId], references: [id])
  client            Client?         @relation("ClientFaults", fields: [clientId], references: [id])
  creator           User            @relation("FaultCreator", fields: [createdBy], references: [id])
  assignedOperative User?           @relation("FaultOperative", fields: [assignedOperativeId], references: [id])
  photos            FaultPhoto[]
  auditLog          FaultAuditLog[]
  eodReports        EodReport[]
  workDays          WorkDay[]

  @@map("faults")
}

// ─── WORK DAYS (GPS Attendance) ─────────────────────────────────────

model WorkDay {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faultId   String  @map("fault_id") @db.Uuid
  dayNumber Int     @map("day_number")
  isLocked  Boolean @default(false) @map("is_locked")

  // Per-day operative report fields
  supervisorNames  String?  @map("supervisor_names")
  tradespersonNames String? @map("tradesperson_names")
  operativeName    String?  @map("operative_name")
  materialsUsed    Json?    @map("materials_used") @db.JsonB
  methodology      String?
  worksDescription String?  @map("works_description")
  dimensions       Json?    @db.JsonB
  tempWorks        Json?    @map("temp_works") @db.JsonB // [{item, qty, unit}]
  furtherWork      Boolean? @map("further_work")
  furtherWorkNotes String?  @map("further_work_notes")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  fault  Fault        @relation(fields: [faultId], references: [id], onDelete: Cascade)
  events PunchEvent[]
  photos FaultPhoto[]

  @@unique([faultId, dayNumber])
  @@map("work_days")
}

model PunchEvent {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workDayId String         @map("work_day_id") @db.Uuid
  eventType PunchEventType @map("event_type")
  timestamp DateTime       @default(now()) @db.Timestamptz()
  lat       Float
  lng       Float

  workDay WorkDay @relation(fields: [workDayId], references: [id], onDelete: Cascade)

  @@map("punch_events")
}

// ─── FAULT PHOTOS ───────────────────────────────────────────────────

model FaultPhoto {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faultId       String    @map("fault_id") @db.Uuid
  workDayId     String?   @map("work_day_id") @db.Uuid
  r2Key         String    @map("r2_key")
  photoStage    String    @map("photo_stage") // 'before' | 'during' | 'after'
  fileName      String?   @map("file_name")
  fileSizeBytes Int?      @map("file_size_bytes")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()
  uploadedAt    DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz()

  fault   Fault    @relation(fields: [faultId], references: [id], onDelete: Cascade)
  workDay WorkDay? @relation(fields: [workDayId], references: [id], onDelete: SetNull)

  @@map("fault_photos")
}

// ─── FAULT AUDIT LOG ────────────────────────────────────────────────

model FaultAuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faultId    String   @map("fault_id") @db.Uuid
  changedBy  String   @map("changed_by") @db.Uuid
  changeType String   @map("change_type")
  oldValue   Json?    @map("old_value") @db.JsonB
  newValue   Json?    @map("new_value") @db.JsonB
  changedAt  DateTime @default(now()) @map("changed_at") @db.Timestamptz()

  fault Fault @relation(fields: [faultId], references: [id])
  user  User  @relation(fields: [changedBy], references: [id])

  @@map("fault_audit_log")
}

// ─── REFRESH TOKENS ─────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String
  isRevoked Boolean  @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── PASSWORD RESET TOKENS ──────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── EMAIL VERIFICATION TOKENS ──────────────────────────────────────

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ─── EOD REPORTS ────────────────────────────────────────────────────

model EodReport {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  faultId   String    @map("fault_id") @db.Uuid
  adminId   String    @map("admin_id") @db.Uuid
  pdfR2Key  String?   @map("pdf_r2_key")
  sentAt    DateTime? @map("sent_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  fault Fault @relation(fields: [faultId], references: [id])
  admin User  @relation(fields: [adminId], references: [id])

  @@map("eod_reports")
}

// ─── AUDIT LOGS (system-wide) ───────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value") @db.JsonB
  newValue   Json?    @map("new_value") @db.JsonB
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── DATA DELETION REQUESTS (UK GDPR Article 17) ───────────────────

model DataDeletionRequest {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestedBy  String    @map("requested_by") @db.Uuid
  targetUserId String    @map("target_user_id") @db.Uuid
  reason       String
  status       String    @default("PENDING")
  processedBy  String?   @map("processed_by") @db.Uuid
  processedAt  DateTime? @map("processed_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  requester User  @relation("DeletionRequester", fields: [requestedBy], references: [id])
  target    User  @relation("DeletionTarget", fields: [targetUserId], references: [id])
  processor User? @relation("DeletionProcessor", fields: [processedBy], references: [id])

  @@map("data_deletion_requests")
}

// ─── RATE CARDS (per-client resource rates) ────────────────────────

model RateCard {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId           String   @map("admin_id") @db.Uuid
  clientId          String   @map("client_id") @db.Uuid
  category          String   // 'Labour' | 'Plant' | 'Material'
  resourceName      String   @map("resource_name")
  dayRateHourly     Float    @default(0) @map("day_rate_hourly") @db.DoublePrecision
  nightRateHourly   Float    @default(0) @map("night_rate_hourly") @db.DoublePrecision
  weekendRateHourly Float    @default(0) @map("weekend_rate_hourly") @db.DoublePrecision
  dayRateShift      Float    @default(0) @map("day_rate_shift") @db.DoublePrecision
  nightRateShift    Float    @default(0) @map("night_rate_shift") @db.DoublePrecision
  weekendRateShift  Float    @default(0) @map("weekend_rate_shift") @db.DoublePrecision
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  admin  User   @relation("AdminRateCards", fields: [adminId], references: [id])
  client Client @relation("ClientRateCards", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, category, resourceName])
  @@map("rate_cards")
}

// ─── QUOTATIONS ────────────────────────────────────────────────────

model Quotation {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId           String          @map("admin_id") @db.Uuid
  clientId          String?         @map("client_id") @db.Uuid
  quotationRef      String          @unique @map("quotation_ref")
  parentId          String?         @map("parent_id") @db.Uuid
  revisionNumber    Int             @default(0) @map("revision_number")
  title             String
  workDescription   String?         @map("work_description")
  methodology       Json?           @db.JsonB // [{ title: string, content: string, sortOrder: number }]
  enabledCategories Json            @default("[\"Labour\",\"Plant\",\"Material\"]") @map("enabled_categories") @db.JsonB
  vatPercent        Float?          @map("vat_percent") @db.DoublePrecision
  status            QuotationStatus @default(DRAFT)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  admin     User            @relation("AdminQuotations", fields: [adminId], references: [id])
  client    Client?         @relation("ClientQuotations", fields: [clientId], references: [id])
  parent    Quotation?      @relation("QuotationRevisions", fields: [parentId], references: [id])
  revisions Quotation[]     @relation("QuotationRevisions")
  items     QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotationId String  @map("quotation_id") @db.Uuid
  itemNo      Int     @map("item_no")
  category    String  // "Labour" | "Plant" | "Material"
  description String
  quantity    Float   @db.DoublePrecision
  unit        String
  rate        Float   @db.DoublePrecision
  uplift      Float   @default(0) @db.DoublePrecision // percentage, e.g. 5 means 5%
  amount      Float   @db.DoublePrecision // qty * rate * (1 + uplift/100)
  rateCardId  String? @map("rate_card_id") @db.Uuid

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}
